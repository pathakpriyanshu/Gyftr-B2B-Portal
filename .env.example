# ============================================================
#  Gyftr B2B Voucher Portal — Environment Variables
#  Copy this file to `.env.local` and replace the placeholder
#  values with your real credentials before going live.
# ============================================================

# ---- App ----
NEXT_PUBLIC_APP_NAME="Gyftr B2B Portal"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Supabase (Database + Storage) ----
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_URL"
# Public anon key (safe for the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# Service-role key — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
# Storage bucket names
SUPABASE_PAYMENT_PROOF_BUCKET="payment-proofs"
SUPABASE_VOUCHER_FILE_BUCKET="voucher-files"

# ---- Auth / Session ----
# 32+ char random secret used to sign session + OTP JWTs.
# Generate with: openssl rand -base64 48
AUTH_JWT_SECRET="CHANGE_ME_super_long_random_secret_min_32_chars_000000"
SESSION_COOKIE_NAME="gyftr_b2b_session"
SESSION_TTL_HOURS="12"

# ---- OTP ----
OTP_LENGTH="6"
OTP_TTL_MINUTES="5"
OTP_RESEND_COOLDOWN_SECONDS="30"
# When true, the generated OTP is returned in the API response and
# logged to the server console (DEV ONLY — never enable in prod).
OTP_DEV_MODE="true"

# ---- Email (transactional) ----
# Plug in your provider. Defaults to console logging when unset.
EMAIL_PROVIDER="console"          # console | resend | smtp
EMAIL_FROM="Gyftr B2B <no-reply@gyftr.net>"
RESEND_API_KEY="YOUR_RESEND_API_KEY"
SMTP_HOST="YOUR_SMTP_HOST"
SMTP_PORT="587"
SMTP_USER="YOUR_SMTP_USER"
SMTP_PASS="YOUR_SMTP_PASS"

# ---- Gyftr Core APIs (Catalog + Voucher issuance) ----
# Base URL of the Gyftr API gateway.
GYFTR_API_BASE_URL="https://dev-uat.gyftr.net/api"
GYFTR_API_KEY="YOUR_GYFTR_API_KEY"
GYFTR_CATALOG_ENDPOINT="/catalog/brands"
GYFTR_SEND_VOUCHER_ENDPOINT="/voucher/issue"
# When true the app uses the built-in mock catalog + mock voucher
# issuance instead of calling the real Gyftr API. Flip to false
# once GYFTR_API_KEY + endpoints are configured.
GYFTR_USE_MOCK="true"

# ---- Payments (Bank transfer details shown at checkout) ----
PAYMENT_BANK_ACCOUNT_NAME="GYFTR pvt. Ltd."
PAYMENT_BANK_ACCOUNT_NUMBER="000111222333444"
PAYMENT_BANK_IFSC="HDFC0000001"
PAYMENT_BANK_NAME="HDFC Bank"
PAYMENT_BANK_BRANCH="Gurugram"
