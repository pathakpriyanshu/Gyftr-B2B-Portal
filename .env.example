# ============================================================
#  Gyftr B2B Voucher Portal — Django Backend Environment
#  Copy this file to `.env` and replace placeholders with real
#  credentials before going live. Out of the box (mock mode) the
#  backend runs on SQLite with zero external services.
# ============================================================

# ---- App ----
APP_NAME="Gyftr B2B Portal"
# Public base URL of THIS Django backend (used to build absolute file URLs).
APP_URL="http://localhost:8000"
# Base URL of the Next.js frontend (used in emailed download links).
FRONTEND_URL="http://localhost:3000"

# ---- Django ----
DJANGO_SECRET_KEY="dev_only_change_me_django_secret_key_00000000000000"
DJANGO_DEBUG="true"
# Comma-separated hosts. "*" allows all (dev only).
DJANGO_ALLOWED_HOSTS="*"

# ---- CORS (the frontend origin[s] allowed to call this API) ----
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# ---- Database ----
# Leave DATABASE_URL empty to use the zero-config SQLite default.
# For Postgres / Supabase, set e.g.
#   postgres://user:pass@host:5432/dbname
DATABASE_URL=""

# ---- Auth / Session ----
# MUST match the Next.js AUTH_JWT_SECRET so the frontend can verify
# the session cookie this backend issues (HS256 JWT).
AUTH_JWT_SECRET="dev_only_change_me_super_long_random_secret_min_32_chars"
SESSION_COOKIE_NAME="gyftr_b2b_session"
SESSION_TTL_HOURS="12"
# Set true when serving the cookie over HTTPS (production).
SESSION_COOKIE_SECURE="false"

# ---- OTP ----
OTP_LENGTH="6"
OTP_TTL_MINUTES="5"
OTP_RESEND_COOLDOWN_SECONDS="30"
# When true, the generated OTP is returned in the API response and logged
# to the server console (DEV ONLY — never enable in prod).
OTP_DEV_MODE="true"

# ---- Email (transactional) ----
EMAIL_PROVIDER="console"          # console | resend
EMAIL_FROM="Gyftr B2B <no-reply@gyftr.net>"
RESEND_API_KEY="YOUR_RESEND_API_KEY"

# ---- Gyftr Core APIs (Catalog + Voucher issuance) ----
GYFTR_API_BASE_URL="https://dev-uat.gyftr.net/api"
GYFTR_API_KEY="YOUR_GYFTR_API_KEY"
GYFTR_CATALOG_ENDPOINT="/catalog/brands"
GYFTR_SEND_VOUCHER_ENDPOINT="/voucher/issue"
# When true the app uses the built-in mock catalog + mock voucher issuance.
GYFTR_USE_MOCK="true"

# ---- Payments (Bank transfer details shown at checkout) ----
PAYMENT_BANK_ACCOUNT_NAME="GYFTR pvt. Ltd."
PAYMENT_BANK_ACCOUNT_NUMBER="000111222333444"
PAYMENT_BANK_IFSC="HDFC0000001"
PAYMENT_BANK_NAME="HDFC Bank"
PAYMENT_BANK_BRANCH="Gurugram"
